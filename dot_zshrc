setopt HIST_FIND_NO_DUPS
setopt EXTENDED_HISTORY

export EDITOR='nvim'
export GPG_TTY="${TTY}"
export HISTSIZE=1000000
export SAVEHIST="$HISTSIZE"
export GOPATH="$HOME/.go"
export GOBIN="$GOPATH/bin"
export HISTFILE="$HOME/.zsh_history"
export FPATH="/opt/homebrew/share/zsh/site-functions:$FPATH"
export PATH="$HOME/.bin:$GOPATH/bin:/opt/homebrew/bin:$PATH"

alias cd='z'
alias g='git'
alias t='tao'
alias p='pnpm'
alias ls='lsd'
alias vim='nvim'
alias ll='lsd -lh'
alias k='kubectl'
alias ch='chezmoi'
alias oc='opencode'
alias lg='lazygit'
alias tree='tree -C'
alias diff='colordiff'
alias history='history -i 0'
alias tmp='cd "$(mktemp -d -t dev)"'
alias weather='curl -s https://wttr.in'
alias myip='curl https://ifconfig.me;echo'
alias cat='bat --paging never --style plain'
alias randomstring=' date +%s | sha256sum | base64 | head -c 32 | tee >(wl-copy); echo'

autoload -Uz compinit
if [[ -n ${ZDOTDIR:-$HOME}/.zcompdump(#qN.mh+24) ]]; then
  compinit
else
  compinit -C
fi

eval "$(direnv hook zsh)"
eval "$(zoxide init zsh)"
eval "$(starship init zsh)"
eval "$(tao completion zsh)"

[ -f "$HOME/.local.zsh" ] && source "$HOME/.local.zsh" || :
