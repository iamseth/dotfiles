{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": false,
      "oauth": false,
      "headers": {
        "Authorization": "{env:MCP_GITHUB_TOKEN}" 
      }
    },
    "trello": {
      "type": "local",
      "command": [
        "bunx",
        "@delorenj/mcp-server-trello"
      ],
      "enabled": false,
      "environment": {
        "TRELLO_TOKEN": "{env:MCP_TRELLO_TOKEN}"
        "TRELLO_API_KEY": "{env:MCP_TRELLO_API_KEY}",
      }
    }
  }
}
