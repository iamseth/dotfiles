{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (LAN)",
      "options": {
        "baseURL": "http://192.168.2.202:11434/v1"
      },
      "models": {
        "qwen2.5-coder:7b": {
          "name": "Qwen2.5 Coder 7B (Ollama)"
        }
      }
    }
  },
  "instructions": [
    "~/.config/opencode/AGENTS.md"
  ],
  "plugin": [
    "@mohak34/opencode-notifier@latest"
  ],
  "mcp": {
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "{env:MCP_GITHUB_TOKEN}" 
      }
    },
    "trello": {
      "type": "local",
      "command": [
        "bunx",
        "@delorenj/mcp-server-trello"
      ],
      "enabled": false,
      "environment": {
        "TRELLO_TOKEN": "{env:MCP_TRELLO_TOKEN}",
        "TRELLO_API_KEY": "{env:MCP_TRELLO_API_KEY}"
      }
    }
  }
}
